# ===========================================
# RotaAI Environment Variables
# ===========================================

# --- DATABASE ---
# SQLite for local dev:
DATABASE_URL="file:./dev.db"
# PostgreSQL for production (Coolify managed):
# DATABASE_URL="postgresql://rotaai:STRONG_PASSWORD@postgres:5432/rotaai"

# --- AUTHENTICATION ---
# MUST change in production — use: openssl rand -base64 64
JWT_SECRET="rotaai-dev-jwt-secret-change-in-production"

# --- AI COPILOT ---
# Google Gemini API key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=""

# --- SERVER ---
NODE_ENV="development"
PORT=3000

# --- PYTHON OPTIMIZATION ENGINE ---
# URL of the FastAPI optimization service
PYTHON_SERVICE_URL="http://localhost:8000"

# --- EXTERNAL INTEGRATIONS ---
# API key for external systems (Epic, Cerner, bed management) to push data
# Generate with: openssl rand -hex 32
INTEGRATION_API_KEY=""

# --- COOLIFY DEPLOYMENT NOTES ---
# In Coolify, set these as environment variables in the service settings:
# 1. DATABASE_URL     — point to your Coolify-managed PostgreSQL
# 2. JWT_SECRET       — generate a strong random secret
# 3. GEMINI_API_KEY   — your Google AI key
# 4. NODE_ENV         — "production"
# 5. PORT             — usually 3000 (Coolify maps this automatically)
# 6. PYTHON_SERVICE_URL — URL of the optimizer service if deployed
# 7. INTEGRATION_API_KEY — for external system webhooks
