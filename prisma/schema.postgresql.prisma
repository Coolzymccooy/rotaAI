generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ORGANIZATION / MULTI-TENANCY
// ============================================

model Organization {
  id          String   @id @default(uuid())
  name        String   // e.g. "Manchester Foundation Trust"
  slug        String   @unique // e.g. "mft" — used in URLs
  type        String   @default("nhs_trust") // "nhs_trust", "private_hospital", "agency"
  logo        String?
  domain      String?  // Optional: auto-assign users from this email domain
  maxUsers    Int      @default(500)
  plan        String   @default("standard") // "trial", "standard", "enterprise"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  doctors     Doctor[]
  shifts      Shift[]
  rules       Rule[]
  invites     Invite[]
  shiftTemplates    ShiftTemplate[]
  serviceRequirements ServiceRequirement[]
  wardStates  WardState[]
  auditLogs   AuditLog[]
  rotaPeriods RotaPeriod[]
  staffRequests StaffRequest[]
  staffMembers StaffMember[]
  locumRequests LocumRequest[]
  approvalRules ApprovalRule[]
}

model Invite {
  id             String    @id @default(uuid())
  organizationId String
  email          String
  role           String    @default("doctor") // "admin" or "doctor"
  token          String    @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdBy      String?
  createdAt      DateTime  @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id])
}

// ============================================
// USERS & AUTH
// ============================================

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String
  name           String
  role           String   @default("doctor")
  // Granular roles: "admin", "rota_coordinator", "department_lead",
  // "doctor", "nurse", "anp", "pa", "pharmacist", "hca",
  // "midwife", "ot", "physio", "paramedic", "porter", "clerk"
  clinicalRole   String?  // More specific than role — the actual job title
  organizationId String?
  doctorId       String?  @unique
  consentGiven   Boolean  @default(false)
  consentDate    DateTime?
  lastLoginAt    DateTime?
  lastLoginIp    String?
  mfaEnabled     Boolean  @default(false)
  isActive       Boolean  @default(true)
  deactivatedAt  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization? @relation(fields: [organizationId], references: [id])
  doctor         Doctor?  @relation(fields: [doctorId], references: [id])
  auditLogs      AuditLog[]
  dataExports    DataExport[]
}

// ============================================
// CLINICAL DATA (all scoped to Organization)
// ============================================

model Doctor {
  id                String   @id @default(uuid())
  organizationId    String?
  doctorCode        String?  @unique
  gmcNumber         String?
  title             String?
  name              String
  firstName         String?
  lastName          String?
  email             String?
  grade             String
  specialty         String?
  department        String   @default("A&E")
  site              String?
  contract          String   @default("100%")
  contractHours     Float?
  fte               String   @default("1.0")
  status            String   @default("Active")
  karma             Int      @default(0)
  fatigue           String   @default("Low")
  maxHours          Float    @default(48.0)
  rotaPattern       String?
  skills            String?
  canDoNights       Boolean  @default(true)
  canDoOncall       Boolean  @default(true)
  trainingDay       String?
  preferredShift    String?
  unavailableDay    String?
  annualLeaveDays   Int?
  studyLeaveDays    Int?
  employmentStart   DateTime?
  employmentEnd     DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization? @relation(fields: [organizationId], references: [id])
  shifts            Shift[]
  leaves            Leave[]
  user              User?
  swapsFrom         ShiftSwap[]  @relation("SwapRequester")
  swapsTo           ShiftSwap[]  @relation("SwapTarget")
  leaveRequests     LeaveRequest[]
  preferences       DoctorPreference?
  historicalLoad    HistoricalLoad?
  availability      Availability[]
  staffRequests     StaffRequest[]   @relation("StaffRequests")
}

model DoctorPreference {
  id               String  @id @default(uuid())
  doctorId         String  @unique
  preferredShift   String?
  unavailableDay   String?
  trainingDay      String?
  priorityFocus    String?
  notes            String?
  fairnessWeight   Int     @default(3)
  preferenceWeight Int     @default(1)
  continuityWeight Int     @default(2)

  doctor           Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model HistoricalLoad {
  id                  String @id @default(uuid())
  doctorId            String @unique
  weekendsYtd         Int    @default(0)
  nightsYtd           Int    @default(0)
  oncallsYtd          Int    @default(0)
  hoursWorkedLast7    Float  @default(0)
  complianceScore     Float  @default(1.0)
  warningFlagsOpen    Int    @default(0)

  doctor              Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model ShiftTemplate {
  id              String  @id @default(uuid())
  organizationId  String?
  templateCode    String  @unique
  shiftType       String
  startTime       String
  endTime         String
  paidHours       Float
  countsTowardLimit Boolean @default(true)
  residentShift   Boolean  @default(true)
  weekendShift    Boolean  @default(false)
  oncallShift     Boolean  @default(false)
  notes           String?

  organization    Organization? @relation(fields: [organizationId], references: [id])
}

model ServiceRequirement {
  id                  String @id @default(uuid())
  organizationId      String?
  site                String
  specialty           String
  department          String
  shiftType           String
  minFyCover          Int    @default(0)
  minShoCover         Int    @default(0)
  minRegistrarCover   Int    @default(0)
  minConsultantCover  Int    @default(0)

  organization        Organization? @relation(fields: [organizationId], references: [id])
}

model Shift {
  id             String       @id @default(uuid())
  organizationId String?
  doctorId       String
  dayIdx         Int
  type           String
  time           String
  date           String?
  isLocum        Boolean      @default(false)
  violation      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization? @relation(fields: [organizationId], references: [id])
  doctor         Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  swaps          ShiftSwap[]
}

// ============================================
// MULTI-HORIZON PLANNING
// ============================================

model RotaPeriod {
  id              String   @id @default(uuid())
  organizationId  String?
  name            String   // e.g., "Q1 2026 Rota", "March 2026 Weekly"
  mode            String   // "annual", "quarterly", "monthly", "weekly", "live"
  status          String   @default("draft") // "draft", "published", "locked", "archived"
  startDate       DateTime
  endDate         DateTime
  createdBy       String?
  publishedAt     DateTime?
  publishedBy     String?
  lockedAt        DateTime?
  notes           String?
  optimizationProfile String? // JSON: fairnessWeight, costWeight, priorities
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization? @relation(fields: [organizationId], references: [id])
}

model Availability {
  id              String   @id @default(uuid())
  doctorId        String
  type            String   // "unavailable", "preferred_off", "preferred_on", "restriction"
  startDate       DateTime
  endDate         DateTime
  reason          String?
  isRecurring     Boolean  @default(false)
  recurringDay    String?  // "Monday", "Tuesday", etc. for recurring weekly blocks
  status          String   @default("active") // "active", "expired", "cancelled"
  createdAt       DateTime @default(now())

  doctor          Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model StaffRequest {
  id              String    @id @default(uuid())
  organizationId  String?
  doctorId        String
  type            String    // "leave", "swap", "preference", "restriction", "shift_offer"
  subType         String?   // "annual", "study", "sick", "compassionate", "night_opt_out", etc.
  title           String
  description     String?
  startDate       DateTime?
  endDate         DateTime?
  targetDoctorId  String?   // For swaps
  targetShiftId   String?   // For swaps
  priority        String    @default("normal") // "low", "normal", "high", "urgent"
  status          String    @default("pending") // "pending", "approved", "rejected", "cancelled"
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNote      String?
  autoApprovable  Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  doctor          Doctor    @relation("StaffRequests", fields: [doctorId], references: [id])
  organization    Organization? @relation(fields: [organizationId], references: [id])
}

// ============================================
// LOCUM / AGENCY REQUESTS
// ============================================

model LocumRequest {
  id              String    @id @default(uuid())
  organizationId  String?
  shiftId         String?   // The unfilled shift that triggered this
  department      String
  grade           String    // Required grade: "Registrar", "Consultant", etc.
  shiftType       String    // "Day", "Night", "Long Day", "Weekend"
  shiftDate       DateTime
  shiftTime       String    // "08:00 - 20:00"
  reason          String    // "sick_cover", "vacancy", "surge", "leave_cover"
  estimatedCost   Float?    // Projected cost in £
  hourlyRate      Float     @default(80)
  hours           Float     @default(12)
  urgency         String    @default("normal") // "low", "normal", "urgent", "emergency"
  status          String    @default("pending") // "pending", "budget_review", "approved", "filled", "rejected", "cancelled"
  requestedBy     String?
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  agencyName      String?   // Which agency fills it
  locumName       String?   // Name of assigned locum
  filledAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization    Organization? @relation(fields: [organizationId], references: [id])
}

// ============================================
// APPROVAL CHAINS
// ============================================

model ApprovalRule {
  id              String  @id @default(uuid())
  organizationId  String?
  requestType     String  // "leave", "locum", "swap", "rota_override", "budget"
  condition       String  // JSON: e.g., {"maxDays": 2} or {"maxCost": 1000}
  approvalLevel   Int     @default(1) // 1 = auto/line manager, 2 = dept head, 3 = director
  approverRole    String  // "auto", "line_manager", "department_lead", "admin", "finance"
  isActive        Boolean @default(true)
  description     String?
  createdAt       DateTime @default(now())

  organization    Organization? @relation(fields: [organizationId], references: [id])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id              String    @id @default(uuid())
  userId          String
  type            String    // "request_approved", "request_rejected", "shift_change", "locum_needed", "swap_request", "rota_published"
  title           String
  message         String
  link            String?   // URL path to navigate to, e.g., "/app/portal"
  isRead          Boolean   @default(false)
  readAt          DateTime?
  createdAt       DateTime  @default(now())
}

model Leave {
  id        String   @id @default(uuid())
  doctorId  String
  type      String
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model LeaveRequest {
  id         String    @id @default(uuid())
  leaveCode  String?   @unique
  doctorId   String
  type       String
  startDate  DateTime
  endDate    DateTime
  duration   Int?
  reason     String?
  status     String    @default("pending")
  requestedVia String?
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  doctor     Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model ShiftSwap {
  id              String   @id @default(uuid())
  shiftId         String
  requesterId     String
  targetDoctorId  String
  targetDayIdx    Int
  reason          String?
  status          String   @default("pending")
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shift           Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  requester       Doctor   @relation("SwapRequester", fields: [requesterId], references: [id])
  targetDoctor    Doctor   @relation("SwapTarget", fields: [targetDoctorId], references: [id])
}

model Rule {
  id             String   @id @default(uuid())
  organizationId String?
  name           String
  description    String
  isActive       Boolean  @default(true)
  category       String   @default("General")
  severity       String   @default("Hard")
  value          String?
  scope          String   @default("global") // "global", "long_range", "mid_range", "short_range", "day_of"
  appliesTo      String?  // JSON: specific departments, grades, sites this rule applies to
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization? @relation(fields: [organizationId], references: [id])
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?
  userId         String?
  action         String
  entity         String
  entityId       String?
  details        String?
  ipAddress      String?
  createdAt      DateTime @default(now())

  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User?    @relation(fields: [userId], references: [id])
}

model IntegrationEvent {
  id            String   @id @default(uuid())
  source        String
  eventType     String
  resourceType  String?
  resourceId    String?
  wardId        String?
  doctorCode    String?
  payload       String?
  status        String   @default("processed")
  errorMessage  String?
  createdAt     DateTime @default(now())
}

model WardState {
  id                String   @id @default(uuid())
  organizationId    String?
  wardCode          String   @unique
  wardName          String
  site              String?
  department        String?
  patients          Int      @default(0)
  capacity          Int      @default(30)
  staffPresent      Int      @default(0)
  staffRequired     Int      @default(3)
  acuityScore       Float    @default(0)
  status            String   @default("stable")
  pendingAdmits     Int      @default(0)
  pendingDischarges Int      @default(0)
  lastEhrSync       DateTime?
  lastStaffSync     DateTime?
  updatedAt         DateTime @updatedAt

  organization      Organization? @relation(fields: [organizationId], references: [id])
}

// ============================================
// DTAC / GDPR COMPLIANCE
// ============================================

model DataExport {
  id             String   @id @default(uuid())
  userId         String
  type           String   // "subject_access_request", "data_export", "right_to_erasure"
  status         String   @default("pending") // "pending", "processing", "completed", "failed"
  format         String   @default("json") // "json", "csv"
  downloadUrl    String?
  requestedAt    DateTime @default(now())
  completedAt    DateTime?
  expiresAt      DateTime?

  user           User     @relation(fields: [userId], references: [id])
}

model ConsentRecord {
  id             String   @id @default(uuid())
  userId         String?
  email          String
  consentType    String   // "data_processing", "communications", "analytics", "third_party_sharing"
  granted        Boolean
  version        String   @default("1.0") // Policy version consented to
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())
  revokedAt      DateTime?
}

model DataRetentionPolicy {
  id             String   @id @default(uuid())
  organizationId String?
  entity         String   // "AuditLog", "IntegrationEvent", "Shift", "LeaveRequest", etc.
  retentionDays  Int      @default(2555) // ~7 years (NHS standard)
  autoDelete     Boolean  @default(false)
  lastPurgedAt   DateTime?
  createdAt      DateTime @default(now())
}

// ============================================
// DEEP AUDIT TRAIL (CQC-grade)
// ============================================

model ChangeLog {
  id             String   @id @default(uuid())
  organizationId String?
  userId         String?
  userName       String?
  userRole       String?
  action         String   // "CREATE", "UPDATE", "DELETE", "VIEW", "EXPORT", "LOGIN", "APPROVE", "REJECT"
  entity         String   // "Shift", "Doctor", "Rule", "LeaveRequest", etc.
  entityId       String?
  fieldName      String?  // Specific field changed (for UPDATE actions)
  oldValue       String?  // Before value
  newValue       String?  // After value
  reason         String?  // Why the change was made
  ipAddress      String?
  userAgent      String?
  sessionId      String?
  createdAt      DateTime @default(now())
}

// ============================================
// CLINICAL ROLES (expanded beyond doctor)
// ============================================

model StaffMember {
  id                String   @id @default(uuid())
  organizationId    String?
  staffCode         String?  @unique
  registrationNumber String? // GMC, NMC, GPhC, HCPC number
  registrationBody  String?  // "GMC", "NMC", "GPhC", "HCPC"
  title             String?
  name              String
  firstName         String?
  lastName          String?
  email             String?
  clinicalRole      String   // See CLINICAL_ROLES reference data for full list (50+ roles)
  roleCategory      String?  // "medical", "nursing", "allied_health", "support", "admin", "emergency"
  band              String?  // NHS pay band: "Band 1" to "Band 9", "Medical" for doctors
  grade             String?  // "Consultant", "Registrar", "Staff Nurse", "Senior Sister", etc.
  specialty         String?
  department        String   @default("General")
  site              String?
  contract          String   @default("100%")
  contractHours     Float?
  fte               String   @default("1.0")
  status            String   @default("Active")
  maxHours          Float    @default(48.0)
  canDoNights       Boolean  @default(true)
  canDoOncall       Boolean  @default(true)
  skills            String?  // Semicolon-separated: "IV access; catheter; ventilator"
  trainingDay       String?
  employmentStart   DateTime?
  employmentEnd     DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization? @relation(fields: [organizationId], references: [id])
}
